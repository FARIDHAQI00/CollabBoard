# TCP Server
PORT=9000
HOST=0.0.0.0

# HTTP / WebSocket bridge for Web UI
HTTP_PORT=8080

# File upload (bytes). Default 8MB
MAX_FILE_SIZE=8388608

# TTL cleanup interval in ms (how often server checks expired messages)
TTL_CLEANUP_INTERVAL=60000

# Max messages retained per room for history
MSG_HISTORY_LIMIT=300

# Shared key passphrase (used to derive AES-256 key with PBKDF2)
# In v2.0 this will be replaced by ECDH key exchange.
SHARED_KEY_PASSPHRASE=chat-encrypted-key-2026-komunikasi-data
